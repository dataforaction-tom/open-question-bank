# Postgres (matches docker-compose.yml)
DATABASE_URL=postgres://qb:qb@localhost:5432/qb
# Separate database for integration tests (vitest; uses a mocked embedder)
TEST_DATABASE_URL=postgres://qb:qb@localhost:5432/qb_test
# Dedicated database for the Playwright e2e suite (real Ollama embeddings).
# Kept separate from the dev DB and qb_test; created automatically by global-setup.
E2E_DATABASE_URL=postgres://qb:qb@localhost:5432/qb_e2e

# Ollama
OLLAMA_URL=http://localhost:11434

# Pinned embedding model (Slice 1 default)
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIM=768

# Dedup-at-source: maximum cosine distance to treat as a candidate match (0–2, smaller = closer)
DEDUP_THRESHOLD=0.15

# Clustering (Slice 2): max cosine distance to join an existing cluster
CLUSTER_THRESHOLD=0.2

# Admin auth (Slice 2)
ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=change-me-to-a-long-random-string

# Reasoning LLM (Slice 3) — provider: ollama (local, default) | ollama-cloud | openrouter | mock
REASONING_PROVIDER=ollama
REASONING_MODEL=qwen2.5:7b
# Ollama Cloud (when REASONING_PROVIDER=ollama-cloud)
OLLAMA_CLOUD_URL=https://ollama.com
OLLAMA_API_KEY=
# OpenRouter (when REASONING_PROVIDER=openrouter)
OPENROUTER_API_KEY=
